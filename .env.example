# ============================================================
# SynthoCore — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# In production, use Doppler for secret management:
#   doppler setup && doppler run -- pnpm start
# NEVER commit .env to version control.
# ============================================================

# ---- Coinbase Developer Platform (CDP) — REQUIRED ----------
CDP_API_KEY=
CDP_API_SECRET=
CDP_WALLET_SEED=

# ---- Bankr.bot — REQUIRED ----------------------------------
BANKR_TOKEN=

# ---- Doppler — REQUIRED (production) -----------------------
DOPPLER_TOKEN=

# ---- X / Twitter API — REQUIRED ----------------------------
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ---- Network -----------------------------------------------
# Options: base-mainnet | base-sepolia
NETWORK=base-sepolia
RPC_URL=https://sepolia.base.org

# ---- Agent Configuration -----------------------------------
SIGNAL_THRESHOLD=0.82
MIN_ENGAGEMENT=100
DEPLOY_GAS_LIMIT=500000
MAX_CONCURRENT_DEPLOYS=5

# ---- Database ----------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/synthocore
REDIS_URL=redis://localhost:6379

# ---- API Server --------------------------------------------
API_PORT=3000
API_SECRET=change_me_in_production

# ---- Logging -----------------------------------------------
LOG_LEVEL=info
