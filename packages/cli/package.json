{
  "name": "@synthocore/cli",
  "version": "1.0.0",
  "description": "SynthoCore CLI — deploy autonomous AI agents from your terminal",
  "license": "Apache-2.0",
  "bin": {
    "synco": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": ["dist", "README.md", "LICENSE"],
