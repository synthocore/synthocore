{
  "name": "@synthocore/core",
  "version": "1.0.0",
  "description": "SynthoCore autonomous agent runtime",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@coinbase/coinbase-sdk": "^0.8.0",
    "viem": "^2.10.0",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "axios": "^1.6.8",
    "zod": "^3.22.4",
    "eventemitter3": "^5.0.1",
    "pino": "^8.19.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  }
}
